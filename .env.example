# ===========================================
# DRC Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production

# Gemini AI (Get from https://aistudio.google.com/app/apikey)
Apps__Gemini__Key=your-gemini-api-key-here

# Meta WhatsApp API (Get from https://developers.facebook.com/)
Apps__Meta__AppName=your-app-name
Apps__Meta__Key=your-webhook-verify-token
Apps__Meta__AccessToken=your-meta-access-token
Apps__Meta__WhatsAppBusinessAccountId=your-account-id
Apps__Meta__WhatsAppBusinessId=your-business-id
Apps__Meta__WhatsAppBusinessPhoneNumberId=your-phone-number-id

# JWT Authentication (Generate a random 32+ char string)
Jwt__Key=your-super-secret-jwt-key-minimum-32-characters

# Redis Connection (Get from Upstash, Redis Cloud, or platform)
ConnectionStrings__redis=redis://default:password@host:port

# API URL (for frontend - set after deploying API)
services__api__http__0=https://your-api-url.onrender.com
