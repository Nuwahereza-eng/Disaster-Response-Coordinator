{
  "Apps": {
    "Google": {
      "Key": "not-needed-using-openstreetmap"
    },
    "Gemini": {
      "Key": "${GEMINI_API_KEY}"
    },
    "Meta": {
      "AppName": "${META_APP_NAME}",
      "Key": "${META_WEBHOOK_KEY}",
      "AccessToken": "${META_ACCESS_TOKEN}",
      "WhatsAppBusinessAccountId": "${META_WHATSAPP_ACCOUNT_ID}",
      "WhatsAppBusinessId": "${META_WHATSAPP_BUSINESS_ID}",
      "WhatsAppBusinessPhoneNumberId": "${META_WHATSAPP_PHONE_ID}"
    }
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "DRC.Api",
    "Audience": "DRC.App"
  },
  "ConnectionStrings": {
    "redis": "${REDIS_URL}",
    "DefaultConnection": "Data Source=drc.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
