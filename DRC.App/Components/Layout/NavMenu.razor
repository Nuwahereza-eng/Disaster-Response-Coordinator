@inject DRC.App.Services.UserClientService UserClient

<nav class="sidebar">
    <a href="" class="logo">
        <div class="logo-icon">
            <i class="bi bi-shield-check"></i>
        </div>
        <span>DIRECO</span>
    </a>

    <div class="nav-links">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <i class="bi bi-robot"></i>
            <span>Emergency Agent</span>
        </NavLink>
        <NavLink class="nav-link" href="profile">
            <i class="bi bi-person-fill"></i>
            <span>My Profile</span>
        </NavLink>
        @if (IsAdmin)
        {
            <NavLink class="nav-link" href="admin">
                <i class="bi bi-speedometer2"></i>
                <span>Admin Dashboard</span>
            </NavLink>
        }
        
        <div class="nav-section">
            <span class="nav-section-label">Emergency Contacts</span>
        </div>
        
        <a href="tel:999" class="nav-link emergency-contact">
            <i class="bi bi-shield-fill"></i>
            <span>Police: 999</span>
        </a>
        <a href="tel:911" class="nav-link emergency-contact">
            <i class="bi bi-heart-pulse-fill"></i>
            <span>Ambulance: 911</span>
        </a>
        <a href="tel:112" class="nav-link emergency-contact">
            <i class="bi bi-fire"></i>
            <span>Fire: 112</span>
        </a>
    </div>
    
    <div class="sidebar-footer">
        <div class="status-indicator">
            <span class="status-dot"></span>
            <span>System Online</span>
        </div>
    </div>
</nav>

@code {
    private bool IsAdmin => UserClient.CurrentUser?.Role?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;
}
