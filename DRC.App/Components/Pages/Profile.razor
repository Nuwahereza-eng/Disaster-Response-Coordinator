@page "/profile"
@rendermode InteractiveServer
@inject UserClientService UserService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using DRC.App.Services

<PageTitle>My Profile - DIRECO</PageTitle>

<div class="profile-container">
    @if (isInitializing)
    {
        <!-- Loading state while auto-signing in the demo user -->
        <div class="auth-loading">
            <div class="loading-spinner"></div>
            <p>Loading your profile...</p>
        </div>
    }
    else
    {
        <!-- User Profile (no login required \u2014 demo mode auto-signs in) -->
        <div class="profile-header">
            <h1><i class="bi bi-person-circle"></i> My Profile</h1>
            <div class="header-actions">
                <a href="/" class="btn btn-primary"><i class="bi bi-chat-dots"></i> Chat with Agent</a>
            </div>
        </div>

        <!-- Quick Access Banner -->
        <div class="quick-access-banner">
            <div class="banner-content">
                <span class="banner-icon"><i class="bi bi-robot"></i></span>
                <div class="banner-text">
                    <strong>Need help?</strong>
                    <span>Chat with our AI agent for emergency assistance, shelter registration, and more.</span>
                </div>
            </div>
            <a href="/" class="btn btn-light">Start Chatting <i class="bi bi-arrow-right"></i></a>
        </div>

        @if (profile != null)
        {
            <div class="profile-section">
                <h3><i class="bi bi-clipboard-data"></i> Personal Information</h3>
                <div class="profile-info">
                    <div class="info-row">
                        <label>Name</label>
                        <span>@profile.FullName</span>
                    </div>
                    <div class="info-row">
                        <label>Email</label>
                        <span>@profile.Email</span>
                    </div>
                    <div class="info-row">
                        <label>Phone</label>
                        <span>@profile.Phone</span>
                    </div>
                    <div class="info-row">
                        <label>Member Since</label>
                        <span>@profile.CreatedAt.ToString("MMMM dd, yyyy")</span>
                    </div>
                </div>
            </div>

            <div class="profile-section">
                <h3><i class="bi bi-person-heart"></i> Next of Kin</h3>
                <p class="section-subtitle">The first person we contact in an emergency. Reachable by SMS, WhatsApp, and email. <strong>Defaults are used live</strong> until you set your own values.</p>

                @if (!isEditingNok)
                {
                    <div class="profile-info">
                        <div class="info-row">
                            <label>Name</label>
                            <span>@(string.IsNullOrWhiteSpace(profile.NextOfKinName) ? "— not set —" : profile.NextOfKinName)</span>
                        </div>
                        <div class="info-row">
                            <label><i class="bi bi-telephone"></i> SMS Phone</label>
                            <span>@(string.IsNullOrWhiteSpace(profile.NextOfKinPhone) ? DefaultNokPhone + " (default)" : profile.NextOfKinPhone)</span>
                        </div>
                        <div class="info-row">
                            <label><i class="bi bi-whatsapp"></i> WhatsApp</label>
                            <span>@(string.IsNullOrWhiteSpace(profile.NextOfKinWhatsApp) ? DefaultNokPhone + " (default)" : profile.NextOfKinWhatsApp)</span>
                        </div>
                        <div class="info-row">
                            <label><i class="bi bi-envelope"></i> Email</label>
                            <span>@(string.IsNullOrWhiteSpace(profile.NextOfKinEmail) ? DefaultNokEmail + " (default)" : profile.NextOfKinEmail)</span>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-primary" @onclick="StartEditNok"><i class="bi bi-pencil"></i> Edit Next of Kin</button>
                }
                else
                {
                    <div class="add-contact-form nok-form">
                        <input type="text" @bind="nokName" placeholder="Name (e.g. Jane Nuwahereza)" />
                        <input type="tel" @bind="nokPhone" placeholder="SMS phone (e.g. 0779081600)" />
                        <input type="tel" @bind="nokWhatsApp" placeholder="WhatsApp number (e.g. 0779081600)" />
                        <input type="email" @bind="nokEmail" placeholder="Email (e.g. nuwaherezapeter34@gmail.com)" />
                        <div class="nok-actions">
                            <button class="btn btn-sm btn-primary" @onclick="SaveNok" disabled="@isSavingNok">
                                @if (isSavingNok) { <span class="spinner-sm"></span> } <i class="bi bi-check-lg"></i> Save
                            </button>
                            <button class="btn btn-sm btn-outline" @onclick="CancelEditNok" disabled="@isSavingNok"><i class="bi bi-x-lg"></i> Cancel</button>
                        </div>
                        @if (!string.IsNullOrEmpty(nokMessage))
                        {
                            <div class="alert @(nokSuccess ? "alert-success" : "alert-danger")">@nokMessage</div>
                        }
                    </div>
                }
            </div>

            <div class="profile-section">
                <h3><i class="bi bi-telephone-fill"></i> Emergency Contacts</h3>
                @if (emergencyContacts != null && emergencyContacts.Any())
                {
                    <div class="contacts-list">
                        @foreach (var contact in emergencyContacts)
                        {
                            <div class="contact-card">
                                <div class="contact-info">
                                    <strong>@contact.FullName</strong>
                                    <span><i class="bi bi-telephone"></i> @contact.Phone</span>
                                    @if (!string.IsNullOrEmpty(contact.Email))
                                    {
                                        <span class="contact-method"><i class="bi bi-envelope"></i> @contact.Email</span>
                                    }
                                    @if (!string.IsNullOrEmpty(contact.WhatsAppNumber))
                                    {
                                        <span class="contact-method"><i class="bi bi-whatsapp"></i> @contact.WhatsAppNumber</span>
                                    }
                                    <small>@contact.Relationship</small>
                                </div>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteContact(contact.Id)"><i class="bi bi-x-lg"></i></button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-text">No emergency contacts added yet.</p>
                }

                <div class="add-contact-form">
                    <input type="text" @bind="newContactName" placeholder="Contact Name *" />
                    <input type="tel" @bind="newContactPhone" placeholder="Phone Number *" />
                    <input type="email" @bind="newContactEmail" placeholder="Email (for notifications)" />
                    <input type="tel" @bind="newContactWhatsApp" placeholder="WhatsApp Number" />
                    <select @bind="newContactRelationship">
                        <option value="">Relationship *</option>
                        <option value="Parent">Parent</option>
                        <option value="Spouse">Spouse</option>
                        <option value="Sibling">Sibling</option>
                        <option value="Child">Child</option>
                        <option value="Friend">Friend</option>
                        <option value="Other">Other</option>
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="AddContact"><i class="bi bi-plus-lg"></i> Add</button>
                    <p class="contact-hint"><i class="bi bi-info-circle"></i> Add email or WhatsApp to receive emergency alerts</p>
                </div>
            </div>

            <div class="profile-section">
                <h3><i class="bi bi-file-text"></i> Request History</h3>
                
                @if (history?.EmergencyRequests?.Any() == true)
                {
                    <h4><i class="bi bi-exclamation-triangle"></i> Emergency Requests</h4>
                    <table class="history-table">
                        <thead>
                            <tr><th>Type</th><th>Location</th><th>Severity</th><th>Status</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var req in history.EmergencyRequests)
                            {
                                <tr>
                                    <td>@req.Type</td>
                                    <td>@req.Location</td>
                                    <td><span class="badge severity-@req.Severity.ToLower()">@req.Severity</span></td>
                                    <td><span class="badge status-@req.Status.ToLower()">@req.Status</span></td>
                                    <td>@req.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (history?.ShelterRegistrations?.Any() == true)
                {
                    <h4><i class="bi bi-house-fill"></i> Shelter Registrations</h4>
                    <table class="history-table">
                        <thead>
                            <tr><th>Family Size</th><th>Shelter</th><th>Status</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var reg in history.ShelterRegistrations)
                            {
                                <tr>
                                    <td>@reg.FamilySize people</td>
                                    <td>@(reg.ShelterName ?? "Pending")</td>
                                    <td><span class="badge status-@reg.Status.ToLower()">@reg.Status</span></td>
                                    <td>@reg.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (history?.EvacuationRequests?.Any() == true)
                {
                    <h4><i class="bi bi-truck"></i> Evacuation Requests</h4>
                    <table class="history-table">
                        <thead>
                            <tr><th>Location</th><th>People</th><th>Priority</th><th>Status</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var evac in history.EvacuationRequests)
                            {
                                <tr>
                                    <td>@evac.Location</td>
                                    <td>@evac.NumberOfPeople</td>
                                    <td><span class="badge priority-@evac.Priority.ToLower()">@evac.Priority</span></td>
                                    <td><span class="badge status-@evac.Status.ToLower()">@evac.Status</span></td>
                                    <td>@evac.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (history?.EmergencyRequests?.Any() != true && 
                     history?.ShelterRegistrations?.Any() != true && 
                     history?.EvacuationRequests?.Any() != true)
                {
                    <p class="empty-text">No request history yet. Your emergency and shelter requests will appear here.</p>
                }
            </div>
        }
    }
</div>

@code {
    private bool showLogin = true;
    private bool isLoading = false;
    private bool isInitializing = true;
    private string? errorMessage;

    // Password visibility toggles
    private bool showLoginPassword = false;
    private bool showRegisterPassword = false;

    // Login fields
    private string loginEmail = "";
    private string loginPassword = "";

    // Register fields
    private string registerName = "";
    private string registerEmail = "";
    private string registerPhone = "";
    private string registerPassword = "";

    // Profile data
    private UserProfileDto? profile;
    private List<EmergencyContactDto>? emergencyContacts;
    private UserHistoryDto? history;

    // New contact form
    private string newContactName = "";
    private string newContactPhone = "";
    private string newContactEmail = "";
    private string newContactWhatsApp = "";
    private string newContactRelationship = "";

    // Next of Kin defaults (shown as placeholders / suggested values)
    private const string DefaultNokPhone = "0779081600";
    private const string DefaultNokEmail = "nuwaherezapeter34@gmail.com";

    private bool isEditingNok = false;
    private bool isSavingNok = false;
    private bool nokSuccess = false;
    private string? nokMessage;
    private string nokName = "";
    private string nokPhone = "";
    private string nokWhatsApp = "";
    private string nokEmail = "";

    protected override async Task OnInitializedAsync()
    {
        // Auth will be checked in OnAfterRenderAsync when JS is available
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Seed an instant demo profile so the UI always has something to render,
            // even if the API is unreachable (cold-start, offline, etc.). The backend
            // auto-login then overwrites this with real data in the background.
            profile ??= new UserProfileDto
            {
                FullName = "Peter Nuwahereza",
                Email = "nuwaherezapeter34@gmail.com",
                Phone = "+256779081600",
                Role = "User",
                CreatedAt = DateTime.UtcNow
            };
            history ??= new UserHistoryDto();
            emergencyContacts ??= new List<EmergencyContactDto>();
            isInitializing = false;
            StateHasChanged();

            // Best-effort: try to load real data from the API in the background.
            try
            {
                await UserService.InitializeAsync();
                var real = await UserService.GetProfileAsync();
                if (real != null) profile = real;
                var contacts = await UserService.GetEmergencyContactsAsync();
                if (contacts != null) emergencyContacts = contacts;
                var hist = await UserService.GetHistoryAsync();
                if (hist != null) history = hist;
            }
            catch { /* keep demo data */ }

            StateHasChanged();
        }
    }

    private async Task LoginAsync()
    {
        errorMessage = null;
        isLoading = true;
        StateHasChanged();

        try
        {
            var result = await UserService.LoginAsync(loginEmail, loginPassword);
            if (result != null)
            {
                // After successful login, redirect to the agent chat
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = "Invalid email or password";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Login failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterAsync()
    {
        errorMessage = null;
        isLoading = true;
        StateHasChanged();

        try
        {
            var result = await UserService.RegisterAsync(registerName, registerEmail, registerPhone, registerPassword);
            if (result != null)
            {
                // After successful registration, redirect to the agent chat
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = "Registration failed. Email may already be in use.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Registration failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadProfile()
    {
        profile = await UserService.GetProfileAsync();
        emergencyContacts = await UserService.GetEmergencyContactsAsync();
        history = await UserService.GetHistoryAsync();
        StateHasChanged();
    }

    private async Task AddContact()
    {
        if (!string.IsNullOrEmpty(newContactName) && !string.IsNullOrEmpty(newContactPhone) && !string.IsNullOrEmpty(newContactRelationship))
        {
            await UserService.AddEmergencyContactAsync(
                newContactName, 
                newContactPhone, 
                newContactRelationship,
                string.IsNullOrWhiteSpace(newContactEmail) ? null : newContactEmail,
                string.IsNullOrWhiteSpace(newContactWhatsApp) ? null : newContactWhatsApp
            );
            newContactName = "";
            newContactPhone = "";
            newContactEmail = "";
            newContactWhatsApp = "";
            newContactRelationship = "";
            emergencyContacts = await UserService.GetEmergencyContactsAsync();
        }
    }

    private async Task DeleteContact(int id)
    {
        await UserService.DeleteEmergencyContactAsync(id);
        emergencyContacts = await UserService.GetEmergencyContactsAsync();
    }

    private void StartEditNok()
    {
        nokMessage = null;
        nokName = profile?.NextOfKinName ?? "";
        nokPhone = string.IsNullOrWhiteSpace(profile?.NextOfKinPhone) ? DefaultNokPhone : profile!.NextOfKinPhone!;
        nokWhatsApp = string.IsNullOrWhiteSpace(profile?.NextOfKinWhatsApp) ? DefaultNokPhone : profile!.NextOfKinWhatsApp!;
        nokEmail = string.IsNullOrWhiteSpace(profile?.NextOfKinEmail) ? DefaultNokEmail : profile!.NextOfKinEmail!;
        isEditingNok = true;
    }

    private void CancelEditNok()
    {
        isEditingNok = false;
        nokMessage = null;
    }

    private async Task SaveNok()
    {
        isSavingNok = true;
        nokMessage = null;
        StateHasChanged();
        try
        {
            var ok = await UserService.UpdateNextOfKinAsync(nokName, nokPhone, nokWhatsApp, nokEmail);
            if (ok)
            {
                profile = await UserService.GetProfileAsync();
                nokSuccess = true;
                nokMessage = "Next of kin saved.";
                isEditingNok = false;
            }
            else
            {
                nokSuccess = false;
                nokMessage = "Could not save. Check the email format and try again.";
            }
        }
        catch (Exception ex)
        {
            nokSuccess = false;
            nokMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSavingNok = false;
            StateHasChanged();
        }
    }

    private void Logout()
    {
        UserService.Logout();
        profile = null;
        emergencyContacts = null;
        history = null;
        StateHasChanged();
    }
}
